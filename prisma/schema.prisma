generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum EventStatus {
  draft
  published
  cancelled
  past
}

enum RSVPStatus {
  going
  waitlisted
  cancelled
}

model Event {
  id             String      @id @default(cuid())
  title          String
  description    String
  location       String
  category       String
  status         EventStatus @default(draft)
  capacity       Int?
  startDatetime  DateTime
  endDatetime    DateTime
  organizerId    String

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  rsvps          Rsvp[]
  @@index([organizerId])
}

model Rsvp {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RSVPStatus
  createdAt DateTime   @default(now())

  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@unique([eventId, userId])
}
