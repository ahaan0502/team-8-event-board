<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Welcome to Local Event Board</h1>
  <p class="text-slate-500">
    Discover and RSVP to local events, or create and manage your own.
  </p>
  <% if (session.authenticatedUser) { %>
    <p class="text-slate-500 mt-2 mb-0">
      Signed in as <strong class="text-slate-700"><%= session.authenticatedUser.displayName %></strong>
      (<%= session.authenticatedUser.email %>, role:
      <strong class="text-slate-700"><%= session.authenticatedUser.role %></strong>).
    </p>
  <% } %>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h2 class="text-xl font-semibold mb-4">Browse Events</h2>
  <div class="flex flex-wrap gap-3">
    <a
      href="/events"
      class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 no-underline"
    >
      All Events
    </a>
    <a
      href="/events?category=Tech"
      class="px-4 py-2 rounded-lg bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 no-underline"
    >
      Tech Events
    </a>
    <a
      href="/events?category=Social"
      class="px-4 py-2 rounded-lg bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 no-underline"
    >
      Social Events
    </a>
    <a
      href="/events?category=Entertainment"
      class="px-4 py-2 rounded-lg bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 no-underline"
    >
      Entertainment
    </a>
    <a
      href="/events?timeframe=week"
      class="px-4 py-2 rounded-lg bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 no-underline"
    >
      This Week
    </a>
    <a
      href="/events?timeframe=weekend"
      class="px-4 py-2 rounded-lg bg-white border border-slate-300 text-slate-700 text-sm font-medium hover:bg-slate-50 no-underline"
    >
      This Weekend
    </a>
  </div>
</section>
