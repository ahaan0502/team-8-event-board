<section class="mb-6 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Welcome to Local Event Board</h1>
  <p class="text-slate-500">
    Discover and RSVP to local events, or create and manage your own.
  </p>

  <% if (session.authenticatedUser) { %>
    <p class="text-slate-500 mt-2 mb-4">
      Signed in as <strong class="text-slate-700"><%= session.authenticatedUser.displayName %></strong>
      (<%= session.authenticatedUser.email %>, role:
      <strong class="text-slate-700"><%= session.authenticatedUser.role %></strong>).
    </p>

    <div class="mt-4 flex flex-wrap gap-3">
      <% if (session.authenticatedUser.role === 'staff' || session.authenticatedUser.role === 'admin') { %>
        <a
          href="/events/new"
          class="inline-block px-5 py-2 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition no-underline"
        >
          + Create Event
        </a>

        <a
          href="/organizer/events"
          class="inline-block px-5 py-2 rounded-lg bg-purple-600 text-white font-medium hover:bg-purple-700 transition no-underline"
        >
          Organizer Dashboard
        </a>
      <% } %>

      <% if (session.authenticatedUser.role === 'user') { %>
        <a
          href="/my-rsvps"
          class="inline-block px-5 py-2 rounded-lg bg-emerald-600 text-white font-medium hover:bg-emerald-700 transition no-underline"
        >
          My RSVPs
        </a>
      <% } %>

      <a
        href="/events"
        class="inline-block px-5 py-2 rounded-lg bg-slate-700 text-white font-medium hover:bg-slate-800 transition no-underline"
      >
        Events
      </a>
    </div>
  <% } else { %>
    <div class="mt-4">
      <a
        href="/events"
        class="inline-block px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 no-underline"
      >
        Events
      </a>
    </div>
  <% } %>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="mb-6 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h2 class="text-xl font-semibold text-slate-800 mb-1">Upcoming This Week</h2>
  <p class="text-sm text-slate-400 mb-4">Published events starting within the next 7 days.</p>

  <% if (upcomingEvents.length === 0) { %>
    <p class="text-slate-400 text-sm italic">No events coming up this week. <a href="/events" class="text-blue-600 hover:underline">Browse all events</a>.</p>
  <% } else { %>
    <ul class="divide-y divide-slate-100">
      <% for (const event of upcomingEvents) { %>
        <li>
          <a
            href="/events/<%= event.id %>"
            class="flex items-center justify-between py-3 px-2 rounded-lg hover:bg-slate-50 transition no-underline group"
          >
            <div>
              <p class="font-medium text-slate-800 group-hover:text-blue-600 transition"><%= event.title %></p>
              <p class="text-xs text-slate-400 mt-0.5"><%= event.location %> &middot; <%= event.category %></p>
            </div>
            <div class="text-right shrink-0 ml-4">
              <p class="text-sm text-slate-600"><%= new Date(event.startDatetime).toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' }) %></p>
              <p class="text-xs text-slate-400"><%= new Date(event.startDatetime).toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' }) %></p>
            </div>
          </a>
        </li>
      <% } %>
    </ul>
  <% } %>
</section>

<section class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h2 class="text-xl font-semibold text-slate-800 mb-1">Recently Added</h2>
  <p class="text-sm text-slate-400 mb-4">The latest published events on the board.</p>

  <% if (recentlyAdded.length === 0) { %>
    <p class="text-slate-400 text-sm italic">No published events yet.</p>
  <% } else { %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% for (const event of recentlyAdded) { %>
        <a
          href="/events/<%= event.id %>"
          class="flex flex-col justify-between p-5 rounded-2xl border border-slate-200 bg-slate-50 hover:bg-blue-50 hover:border-blue-200 hover:shadow-md transition no-underline group"
        >
          <div>
            <span class="inline-block text-xs font-medium text-blue-700 bg-blue-100 px-2 py-0.5 rounded-full mb-2"><%= event.category %></span>
            <p class="text-base font-semibold text-slate-900 group-hover:text-blue-700 transition leading-snug"><%= event.title %></p>
            <p class="text-sm text-slate-500 mt-1"><%= event.location %></p>
          </div>
          <div class="mt-4 pt-3 border-t border-slate-200 flex items-center justify-between">
            <p class="text-sm font-medium text-slate-700"><%= new Date(event.startDatetime).toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' }) %></p>
            <p class="text-xs text-slate-400">Added <%= new Date(event.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric' }) %></p>
          </div>
        </a>
      <% } %>
    </div>
  <% } %>
</section>