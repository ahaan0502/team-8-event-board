<h2>Upcoming</h2>
<% if (dashboard.upcoming.length === 0) { %>
  <p>No upcoming RSVPs.</p>
<% } %>
<% dashboard.upcoming.forEach(item => { %>
  <div class="mb-3">
    <strong><%= item.event.title %></strong>
    <form
      class="inline-block ml-2"
      hx-post="/events/<%= item.event.id %>/rsvp"
      hx-target="#my-rsvps-sections"
      hx-select="#my-rsvps-sections"
      hx-swap="outerHTML"
    >
      <button type="submit" class="px-2 py-1 rounded bg-red-100 text-red-700 text-sm hover:bg-red-200">
        Cancel RSVP
      </button>
    </form>
  </div>
<% }) %>

<h2>Past/Cancelled</h2>
<% if (dashboard.pastCancelled.length === 0) { %>
  <p>No past or cancelled RSVPs.</p>
<% } %>
<% dashboard.pastCancelled.forEach(item => { %>
  <div>
    <strong><%= item.event.title %></strong>
  </div>
<% }) %>