<section class="space-y-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Member Dashboard</p>
      <h1 class="text-3xl font-bold text-slate-900">My RSVPs</h1>
      <p class="mt-1 text-slate-600">Track upcoming events and manage your RSVPs in one place.</p>
    </div>

    <button
      class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-blue-400"
      hx-get="/my-rsvps"
      hx-target="#my-rsvps-sections"
      hx-swap="innerHTML"
    >
      Refresh
    </button>
  </div>

  <div id="my-rsvps-sections">
    <%- include("partials/dashboard-sections", { dashboard }) %>
  </div>
</section>