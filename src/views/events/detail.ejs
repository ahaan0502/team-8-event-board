<h1><%= event.title %></h1>

<p><strong>Description:</strong> <%= event.description %></p>

<p><strong>Location:</strong> <%= event.location %></p>

<p><strong>Category:</strong> <%= event.category %></p>

<p>
  <strong>Start:</strong>
  <%= event.startDatetime ? new Date(event.startDatetime).toLocaleString() : "N/A" %>
</p>

<p>
  <strong>End:</strong>
  <%= event.endDatetime ? new Date(event.endDatetime).toLocaleString() : "N/A" %>
</p>

<p><strong>Capacity:</strong> <%= event.capacity %></p>

<p><strong>Status:</strong> <%= event.status %></p>

<p><strong>Organizer ID:</strong> <%= event.organizerId %></p>

<div id="rsvp-section">
  <form
    hx-post="/events/<%= event.id %>/rsvp"
    hx-target="#rsvp-section"
    hx-swap="outerHTML"
  >
    <button type="submit">
      Toggle RSVP
    </button>
  </form>

  <p>
    Your RSVP: <%= event.rsvpStatus || "none" %>
  </p>
</div>