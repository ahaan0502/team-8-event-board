<div class="max-w-3xl mx-auto p-4 space-y-6">

  <div>
    <h1 class="text-3xl font-bold"><%= event.title %></h1>
    <p class="text-gray-500 mt-1">
      <%= event.location %> • <%= event.category %>
    </p>
  </div>

  <div class="bg-white p-4 rounded-xl shadow">
    <p class="text-gray-700 whitespace-pre-line">
      <%= event.description %>
    </p>
  </div>

  <% const user = session?.authenticatedUser ?? null; %>

  <% if (user && (user.userId === event.organizerId || user.role === "admin")) { %>
    <a
      href="/events/<%= event.id %>/edit"
      class="inline-flex items-center gap-2 mt-3 px-4 py-2 rounded-lg bg-blue-600 text-white font-medium shadow hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-400 transition"
    >
      Edit Event
    </a>
    <%- include('partials/organizer-controls', { event, session }) %>
  <% } %>

  <% if (user && user.role === "user") { %>
    <%- include('partials/rsvpSection', { event }) %>
  <% } %>

  <div
    x-data="{
      start: new Date('<%= event.startDatetime.toISOString() %>'),
      label: '',
      init() {
        const now = new Date();
        const diff = Math.ceil((this.start - now) / (1000 * 60 * 60 * 24));

        if (diff === 0) this.label = 'today';
        else if (diff === 1) this.label = 'tomorrow';
        else if (diff > 1) this.label = `in ${diff} days`;
        else this.label = 'in the past';
      }
    }"
    x-init="init()"
    class="text-sm text-gray-600"
  >
    <p>
      <%= event.startDatetime.toLocaleString() %>
      <span class="ml-2 text-gray-400" x-text="'(' + label + ')'"></span>
    </p>
  </div>

</div>