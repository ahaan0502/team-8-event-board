<div class="max-w-3xl">
  <div class="mb-4">
    <a href="/home" class="text-blue-600 text-sm hover:underline">&larr; Back</a>
  </div>

  <section class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg mb-4">
    <div class="flex items-start justify-between gap-4 mb-4">
      <h1 class="text-2xl font-bold text-slate-900"><%= event.title %></h1>
      <%- include("partials/status-badge", { status: event.status }) %>
    </div>

    <p class="text-slate-600 mb-5"><%= event.description %></p>

    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <div>
        <dt class="text-slate-400 font-medium">Location</dt>
        <dd class="text-slate-700"><%= event.location %></dd>
      </div>
      <div>
        <dt class="text-slate-400 font-medium">Category</dt>
        <dd class="text-slate-700 capitalize"><%= event.category %></dd>
      </div>
      <div>
        <dt class="text-slate-400 font-medium">Starts</dt>
        <dd class="text-slate-700"><%= new Date(event.startTime).toLocaleString() %></dd>
      </div>
      <div>
        <dt class="text-slate-400 font-medium">Ends</dt>
        <dd class="text-slate-700"><%= new Date(event.endTime).toLocaleString() %></dd>
      </div>
      <div>
        <dt class="text-slate-400 font-medium">Capacity</dt>
        <dd class="text-slate-700"><%= event.capacity %> spots</dd>
      </div>
    </dl>
  </section>

  <%- include("partials/organizer-controls", { event, session }) %>
</div>
