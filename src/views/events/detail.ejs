<%
  const user = session?.authenticatedUser ?? null;
  const isOrganizerOrAdmin = user && (user.role === "admin" || user.userId === event.organizerId);
  const statusColors = {
    draft: "bg-yellow-100 text-yellow-800 border-yellow-200",
    published: "bg-green-100 text-green-800 border-green-200",
    cancelled: "bg-red-100 text-red-800 border-red-200",
    past: "bg-slate-100 text-slate-600 border-slate-200",
  };
  const badgeClass = statusColors[event.status] ?? statusColors.past;
%>

<div class="max-w-3xl">
  <div class="mb-4">
    <a href="/home" class="text-blue-600 text-sm hover:underline">&larr; Back</a>
  </div>

  <section class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg mb-4">
    <div class="flex items-start justify-between gap-4 mb-4">
      <h1 class="text-2xl font-bold text-slate-900"><%= event.title %></h1>
      <span class="shrink-0 px-3 py-1 rounded-full border text-sm font-medium capitalize <%= badgeClass %>">
        <%= event.status %>
      </span>
    </div>

    <p class="text-slate-600 mb-5"><%= event.description %></p>

    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      <div>
        <dt class="text-slate-400 font-medium">Location</dt>
        <dd class="text-slate-700"><%= event.location %></dd>
      </div>
      <div>
        <dt class="text-slate-400 font-medium">Category</dt>
        <dd class="text-slate-700 capitalize"><%= event.category %></dd>
      </div>
      <div>
        <dt class="text-slate-400 font-medium">Starts</dt>
        <dd class="text-slate-700"><%= new Date(event.startTime).toLocaleString() %></dd>
      </div>
      <div>
        <dt class="text-slate-400 font-medium">Ends</dt>
        <dd class="text-slate-700"><%= new Date(event.endTime).toLocaleString() %></dd>
      </div>
      <div>
        <dt class="text-slate-400 font-medium">Capacity</dt>
        <dd class="text-slate-700"><%= event.capacity %> spots</dd>
      </div>
    </dl>
  </section>

  <% if (isOrganizerOrAdmin) { %>
    <section class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg">
      <h2 class="text-base font-semibold text-slate-700 mb-3">Organizer Controls</h2>
      <div class="flex gap-3 flex-wrap">

        <% if (event.status === "draft") { %>
          <form method="post" action="/events/<%= event.id %>/publish">
            <button
              type="submit"
              class="px-4 py-2 rounded-lg bg-green-600 text-white font-medium text-sm cursor-pointer hover:bg-green-700"
            >
              Publish Event
            </button>
          </form>
        <% } %>

        <% if (event.status === "published") { %>
          <form method="post" action="/events/<%= event.id %>/cancel">
            <button
              type="submit"
              class="px-4 py-2 rounded-lg bg-red-600 text-white font-medium text-sm cursor-pointer hover:bg-red-700"
            >
              Cancel Event
            </button>
          </form>
        <% } %>

        <% if (event.status === "cancelled" || event.status === "past") { %>
          <p class="text-slate-400 text-sm italic">No actions available for this event.</p>
        <% } %>

      </div>
    </section>
  <% } %>
</div>
