<h1>Edit Event</h1>

<div id="edit-form">
  <form
    hx-post="/events/<%= event.id %>"
    hx-target="#edit-form"
    hx-swap="outerHTML"
  >
    <div>
      <label>Title</label>
      <input type="text" name="title" value="<%= event.title %>" required />
    </div>

    <div>
      <label>Description</label>
      <textarea name="description" required><%= event.description %></textarea>
    </div>

    <div>
      <label>Location</label>
      <input type="text" name="location" value="<%= event.location %>" required />
    </div>

    <div>
      <label>Category</label>
      <input type="text" name="category" value="<%= event.category %>" required />
    </div>

    <div>
      <label>Start Time</label>
      <input
        type="datetime-local"
        name="startTime"
        value="<%= event.startDatetime ? new Date(event.startDatetime).toISOString().slice(0,16) : '' %>"
        required
      />
    </div>

    <div>
      <label>End Time</label>
      <input
        type="datetime-local"
        name="endTime"
        value="<%= event.endDatetime ? new Date(event.endDatetime).toISOString().slice(0,16) : '' %>"
        required
      />
    </div>

    <div>
      <label>Capacity</label>
      <input
        type="number"
        name="capacity"
        min="1"
        value="<%= event.capacity %>"
        required
      />
    </div>

    <button type="submit">Update Event</button>
  </form>

  <% if (pageError) { %>
    <p style="color: red;"><%= pageError %></p>
  <% } %>
</div>