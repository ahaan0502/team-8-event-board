<h2>Draft</h2>
<% if (dashboard.draft.length === 0) { %>
  <p>No draft events.</p>
<% } %>
<% dashboard.draft.forEach(item => { %>
  <div>
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
  </div>
<% }) %>

