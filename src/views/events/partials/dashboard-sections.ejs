<h2>Draft</h2>
<% if (dashboard.draft.length === 0) { %>
  <p>No draft events.</p>
<% } %>
<% dashboard.draft.forEach(item => { %>
  <div class="mb-3 flex flex-wrap items-center gap-2">
    <span><strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %></span>
    <button
      type="button"
      class="px-2 py-1 text-sm rounded bg-emerald-100 border border-emerald-300 hover:bg-emerald-200"
      hx-post="/events/<%= item.event.id %>/publish"
      hx-swap="none"
      hx-on::after-request="if (event.detail.successful) htmx.ajax('GET', '/organizer/events', { target: '#organizer-dashboard-sections', swap: 'innerHTML' })"
    >
      Publish
    </button>
  </div>
<% }) %>

<h2>Published</h2>
<% if (dashboard.published.length === 0) { %>
  <p>No published events.</p>
<% } %>
<% dashboard.published.forEach(item => { %>
  <div class="mb-3 flex flex-wrap items-center gap-2">
    <span><strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %></span>
    <button
      type="button"
      class="px-2 py-1 text-sm rounded bg-amber-100 border border-amber-300 hover:bg-amber-200"
      hx-post="/events/<%= item.event.id %>/cancel"
      hx-swap="none"
      hx-on::after-request="if (event.detail.successful) htmx.ajax('GET', '/organizer/events', { target: '#organizer-dashboard-sections', swap: 'innerHTML' })"
    >
      Cancel event
    </button>
  </div>
<% }) %>

<h2>Cancelled</h2>
<% if (dashboard.cancelled.length === 0) { %>
  <p>No cancelled events.</p>
<% } %>
<% dashboard.cancelled.forEach(item => { %>
  <div>
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
  </div>
<% }) %>

<h2>Past</h2>
<% if (dashboard.past.length === 0) { %>
  <p>No past events.</p>
<% } %>
<% dashboard.past.forEach(item => { %>
  <div>
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
  </div>
<% }) %>