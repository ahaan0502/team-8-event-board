<h2>Draft</h2>
<% if (dashboard.draft.length === 0) { %>
  <p>No draft events.</p>
<% } %>
<% dashboard.draft.forEach(item => { %>
  <div class="mb-3">
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
    <form
      class="inline-block ml-2"
      hx-post="/events/<%= item.event.id %>/publish"
      hx-target="#organizer-dashboard-sections"
      hx-select="#organizer-dashboard-sections"
      hx-swap="outerHTML"
    >
      <button type="submit" class="px-2 py-1 rounded bg-green-100 text-green-800 text-sm hover:bg-green-200">
        Publish
      </button>
    </form>
  </div>
<% }) %>

<h2>Published</h2>
<% if (dashboard.published.length === 0) { %>
  <p>No published events.</p>
<% } %>
<% dashboard.published.forEach(item => { %>
  <div class="mb-3">
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
    <form
      class="inline-block ml-2"
      hx-post="/events/<%= item.event.id %>/cancel"
      hx-target="#organizer-dashboard-sections"
      hx-select="#organizer-dashboard-sections"
      hx-swap="outerHTML"
    >
      <button type="submit" class="px-2 py-1 rounded bg-red-100 text-red-700 text-sm hover:bg-red-200">
        Cancel
      </button>
    </form>
  </div>
<% }) %>

<h2>Cancelled</h2>
<% if (dashboard.cancelled.length === 0) { %>
  <p>No cancelled events.</p>
<% } %>
<% dashboard.cancelled.forEach(item => { %>
  <div>
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
  </div>
<% }) %>

<h2>Past</h2>
<% if (dashboard.past.length === 0) { %>
  <p>No past events.</p>
<% } %>
<% dashboard.past.forEach(item => { %>
  <div>
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
  </div>
<% }) %>