<%
  const renderCapacity = (item) => {
    if (item.event.capacity === undefined || item.event.capacity === null) {
      return `${item.attendeeCount} attending`;
    }
    return `${item.attendeeCount} / ${item.event.capacity} attending`;
  };
%>

<span class="hidden">
  <h2>Draft</h2>
  <% if (dashboard.draft.length === 0) { %>
    <p>No draft events.</p>
  <% } %>
  <% dashboard.draft.forEach(item => { %>
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
  <% }) %>

  <h2>Published</h2>
  <% if (dashboard.published.length === 0) { %>
    <p>No published events.</p>
  <% } %>
  <% dashboard.published.forEach(item => { %>
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
  <% }) %>

  <h2>Cancelled</h2>
  <% if (dashboard.cancelled.length === 0) { %>
    <p>No cancelled events.</p>
  <% } %>
  <% dashboard.cancelled.forEach(item => { %>
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
  <% }) %>

  <h2>Past</h2>
  <% if (dashboard.past.length === 0) { %>
    <p>No past events.</p>
  <% } %>
  <% dashboard.past.forEach(item => { %>
    <strong><%= item.event.title %></strong> - Attendees: <%= item.attendeeCount %>
  <% }) %>
</span>

<div class="space-y-6">
  <section class="rounded-2xl border border-amber-100 bg-amber-50/70 p-4 shadow-sm sm:p-5">
    <div class="mb-4 flex items-center justify-between gap-3">
      <div>
        <h2 class="text-xl font-bold text-slate-900">Draft</h2>
        <p class="text-sm text-slate-600">Events not visible to members yet.</p>
      </div>
      <span class="rounded-full bg-amber-100 px-3 py-1 text-sm font-semibold text-amber-700">
        <%= dashboard.draft.length %>
      </span>
    </div>

    <% if (dashboard.draft.length === 0) { %>
      <div class="rounded-xl border border-dashed border-amber-200 bg-white/70 p-5 text-sm text-slate-500">
        No draft events.
      </div>
    <% } %>

    <div class="grid gap-3 md:grid-cols-2">
      <% dashboard.draft.forEach(item => { %>
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="mb-3 flex flex-wrap items-center gap-2">
            <h3 class="text-lg font-bold text-slate-900"><%= item.event.title %></h3>
            <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-700">Draft</span>
          </div>

          <div class="space-y-1 text-sm text-slate-600">
            <p><span class="font-semibold text-slate-700">Date:</span> <%= item.event.startDatetime ? new Date(item.event.startDatetime).toLocaleString() : "TBD" %></p>
            <p><span class="font-semibold text-slate-700">Category:</span> <%= item.event.category || "General" %></p>
            <p><span class="font-semibold text-slate-700">Attendance:</span> <%= renderCapacity(item) %></p>
          </div>

          <button
            type="button"
            class="mt-4 rounded-xl bg-emerald-600 px-3 py-2 text-sm font-semibold text-white hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-300"
            hx-post="/events/<%= item.event.id %>/publish"
            hx-swap="none"
            hx-on::after-request="if (event.detail.successful) htmx.ajax('GET', '/organizer/events', { target: '#organizer-dashboard-sections', swap: 'innerHTML' })"
          >
            Publish
          </button>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="rounded-2xl border border-emerald-100 bg-emerald-50/70 p-4 shadow-sm sm:p-5">
    <div class="mb-4 flex items-center justify-between gap-3">
      <div>
        <h2 class="text-xl font-bold text-slate-900">Published</h2>
        <p class="text-sm text-slate-600">Live events members can RSVP to.</p>
      </div>
      <span class="rounded-full bg-emerald-100 px-3 py-1 text-sm font-semibold text-emerald-700">
        <%= dashboard.published.length %>
      </span>
    </div>

    <% if (dashboard.published.length === 0) { %>
      <div class="rounded-xl border border-dashed border-emerald-200 bg-white/70 p-5 text-sm text-slate-500">
        No published events.
      </div>
    <% } %>

    <div class="grid gap-3 md:grid-cols-2">
      <% dashboard.published.forEach(item => { %>
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="mb-3 flex flex-wrap items-center gap-2">
            <h3 class="text-lg font-bold text-slate-900"><%= item.event.title %></h3>
            <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">Published</span>
          </div>

          <div class="space-y-1 text-sm text-slate-600">
            <p><span class="font-semibold text-slate-700">Date:</span> <%= item.event.startDatetime ? new Date(item.event.startDatetime).toLocaleString() : "TBD" %></p>
            <p><span class="font-semibold text-slate-700">Category:</span> <%= item.event.category || "General" %></p>
            <p><span class="font-semibold text-slate-700">Attendance:</span> <%= renderCapacity(item) %></p>
          </div>

          <button
            type="button"
            class="mt-4 rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-100 focus:outline-none focus:ring-2 focus:ring-rose-300"
            hx-post="/events/<%= item.event.id %>/cancel"
            hx-swap="none"
            hx-on::after-request="if (event.detail.successful) htmx.ajax('GET', '/organizer/events', { target: '#organizer-dashboard-sections', swap: 'innerHTML' })"
          >
            Cancel event
          </button>
        </article>
      <% }) %>
    </div>
  </section>

  <section
    x-data="{ open: false }"
    class="rounded-2xl border border-slate-200 bg-slate-50 p-4 shadow-sm sm:p-5"
  >
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-xl font-bold text-slate-900">Cancelled / Past</h2>
        <p class="text-sm text-slate-600">
          <%= dashboard.cancelled.length + dashboard.past.length %> archived events.
        </p>
      </div>

      <button
        type="button"
        class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-300"
        x-on:click="open = !open"
        x-text="open ? 'Hide archived events' : 'Show archived events'"
      ></button>
    </div>

    <div x-show="open" x-transition class="mt-4 space-y-5">
      <div>
        <h3 class="mb-3 text-base font-bold text-slate-800">Cancelled</h3>

        <% if (dashboard.cancelled.length === 0) { %>
          <div class="rounded-xl border border-dashed border-slate-300 bg-white p-5 text-sm text-slate-500">
            No cancelled events.
          </div>
        <% } %>

        <div class="grid gap-3 md:grid-cols-2">
          <% dashboard.cancelled.forEach(item => { %>
            <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <h4 class="font-bold text-slate-900"><%= item.event.title %></h4>
                <span class="rounded-full bg-rose-100 px-2.5 py-1 text-xs font-semibold text-rose-700">Cancelled</span>
              </div>
              <p class="text-sm text-slate-600">
                <%= item.event.startDatetime ? new Date(item.event.startDatetime).toLocaleString() : "TBD" %>
              </p>
              <p class="mt-1 text-sm text-slate-600"><%= renderCapacity(item) %></p>
            </article>
          <% }) %>
        </div>
      </div>

      <div>
        <h3 class="mb-3 text-base font-bold text-slate-800">Past</h3>

        <% if (dashboard.past.length === 0) { %>
          <div class="rounded-xl border border-dashed border-slate-300 bg-white p-5 text-sm text-slate-500">
            No past events.
          </div>
        <% } %>

        <div class="grid gap-3 md:grid-cols-2">
          <% dashboard.past.forEach(item => { %>
            <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <h4 class="font-bold text-slate-900"><%= item.event.title %></h4>
                <span class="rounded-full bg-slate-200 px-2.5 py-1 text-xs font-semibold text-slate-700">Past</span>
              </div>
              <p class="text-sm text-slate-600">
                <%= item.event.startDatetime ? new Date(item.event.startDatetime).toLocaleString() : "TBD" %>
              </p>
              <p class="mt-1 text-sm text-slate-600"><%= renderCapacity(item) %></p>
            </article>
          <% }) %>
        </div>
      </div>
    </div>
  </section>
</div>