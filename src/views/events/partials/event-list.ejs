<% if (events.length === 0) { %>
  <p>No events found.</p>
<% } else { %>
  <ul>
    <% events.forEach((event) => { %>
      <li>
        <strong><%= event.title %></strong>
        <div><%= event.category %></div>
        <div><%= event.location %></div>
        <div><%= new Date(event.startDatetime).toLocaleString() %></div>
      </li>
    <% }) %>
  </ul>
<% } %>