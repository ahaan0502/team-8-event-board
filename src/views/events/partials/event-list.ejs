<div id="event-list">
  <% if (events.length === 0) { %>
    <p class="text-slate-500">No upcoming events match your search or filters.</p>
  <% } else { %>
    <ul class="space-y-4">
      <% for (const event of events) { %>
        <li class="border rounded p-4 bg-white shadow-sm">
          <a href="/events/<%= event.id %>" class="text-lg font-semibold text-blue-700 hover:underline">
            <%= event.title %>
          </a>
          <p class="text-sm text-slate-500 mt-1">
            <%= event.category %> &middot;
            <%= event.startDatetime.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" }) %>
            <%= event.startDatetime.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" }) %>
          </p>
          <p class="text-sm text-slate-600 mt-1"><%= event.location %></p>
        </li>
      <% } %>
    </ul>
  <% } %>
</div>
