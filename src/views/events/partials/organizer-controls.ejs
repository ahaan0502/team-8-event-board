<%
  const user = session?.authenticatedUser ?? null;
  const isOrganizerOrAdmin = user && (user.role === "admin" || user.userId === event.organizerId);
%>
<div id="organizer-controls">
<% if (isOrganizerOrAdmin) { %>
  <section class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg">
    <h2 class="text-base font-semibold text-slate-700 mb-3">Organizer Controls</h2>

    <div class="mb-3">
      <% const statusColors = { draft: "bg-yellow-100 text-yellow-800 border-yellow-200", published: "bg-green-100 text-green-800 border-green-200", cancelled: "bg-red-100 text-red-800 border-red-200", past: "bg-slate-100 text-slate-600 border-slate-200" }; %>
      <span class="px-3 py-1 rounded-full border text-sm font-medium capitalize <%= statusColors[event.status] ?? statusColors.past %>">
        <%= event.status %>
      </span>
    </div>

    <div class="flex gap-3 flex-wrap">
      <% if (event.status === "draft") { %>
        <form
          hx-post="/events/<%= event.id %>/publish"
          hx-target="#organizer-controls"
          hx-swap="outerHTML"
        >
          <button type="submit" class="px-4 py-2 rounded-lg bg-green-600 text-white font-medium text-sm cursor-pointer hover:bg-green-700">
            Publish Event
          </button>
        </form>
      <% } %>

      <% if (event.status === "published") { %>
        <form
          hx-post="/events/<%= event.id %>/cancel"
          hx-target="#organizer-controls"
          hx-swap="outerHTML"
        >
          <button type="submit" class="px-4 py-2 rounded-lg bg-red-600 text-white font-medium text-sm cursor-pointer hover:bg-red-700">
            Cancel Event
          </button>
        </form>
      <% } %>

      <% if (event.status === "cancelled" || event.status === "past") { %>
        <p class="text-slate-400 text-sm italic">No actions available for this event.</p>
      <% } %>

      <a href="/events/<%= event.id %>/attendees"
         class="px-4 py-2 rounded-lg bg-slate-100 text-slate-700 font-medium text-sm hover:bg-slate-200 inline-block">
        View Attendees
      </a>
    </div>
  </section>
<% } %>
</div>
