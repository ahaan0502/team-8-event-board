<%
  const user = session?.authenticatedUser ?? null;
  const isOrganizerOrAdmin = user && (user.role === "admin" || user.userId === event.organizerId);
%>
<% if (isOrganizerOrAdmin) { %>
  <section class="p-5 border border-slate-200 rounded-2xl bg-white shadow-lg">
    <h2 class="text-base font-semibold text-slate-700 mb-3">Organizer Controls</h2>
    <div class="flex gap-3 flex-wrap items-center">

      <% if (event.status === "draft") { %>
        <form method="post" action="/events/<%= event.id %>/publish">
          <button
            type="submit"
            class="px-4 py-2 rounded-lg bg-green-600 text-white font-medium text-sm cursor-pointer hover:bg-green-700"
          >
            Publish Event
          </button>
        </form>
      <% } %>

      <% if (event.status === "published") { %>
        <form method="post" action="/events/<%= event.id %>/cancel">
          <button
            type="submit"
            class="px-4 py-2 rounded-lg bg-red-600 text-white font-medium text-sm cursor-pointer hover:bg-red-700"
          >
            Cancel Event
          </button>
        </form>
      <% } %>

      <% if (event.status === "cancelled" || event.status === "past") { %>
        <p class="text-slate-400 text-sm italic">No actions available for this event.</p>
      <% } %>

      <a
        href="/events/<%= event.id %>/attendees"
        class="px-4 py-2 rounded-lg bg-slate-100 text-slate-700 font-medium text-sm hover:bg-slate-200 no-underline"
      >
        View Attendees
      </a>

    </div>
  </section>
<% } %>
