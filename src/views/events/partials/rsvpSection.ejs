<div id="rsvp-section">
  <button
    hx-post="/events/<%= event.id %>/rsvp"
    hx-target="#rsvp-section"
    hx-swap="outerHTML"
    class="
      px-4 py-2 rounded-lg font-semibold transition
      <% if (event.rsvpStatus === 'going') { %>
        bg-green-500 text-white
      <% } else if (event.rsvpStatus === 'waitlisted') { %>
        bg-yellow-400 text-black
      <% } else { %>
        bg-gray-300 text-black
      <% } %>
    "
  >
    Toggle RSVP
  </button>

  <p>
    Your RSVP: <%= event.rsvpStatus || "none" %>
  </p>
</div>